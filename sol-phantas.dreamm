//
// Phantasmagoria
//
desc[sol-phantas]:

name = Phantasmagoria
icon = sol-phantas.png
machine = pc
osenv = dos
rootpath = C:\
launch = $(rootpath)\SIERRA.EXE
mips = $(MIPS_P75)
nothrottle = 3
ramkb = 16384
videohw = svga
filter = sierra, adventure
RESCONFIG = [[[$(CRLF)
    sync     = .\;.\DISC1;.\DISC2;.\DISC3;.\DISC4;.\DISC5;.\DISC6;.\DISC7
    resMap   = .\;.\DISC1;.\DISC2;.\DISC3;.\DISC4;.\DISC5;.\DISC6;.\DISC7
    resAUD   = .\
    resSFX   = .\DISC1;.\DISC2;.\DISC3;.\DISC4;.\DISC5;.\DISC6;.\DISC7
    resCDisc = .\;.\DISC1;.\DISC2;.\DISC3;.\DISC4;.\DISC5;.\DISC6;.\DISC7
]]]

//
// sound configuration
//
config[sound]:
    title = Sound Configuration
    option[sadl]:
        name = $(ADLIB_NAME) + $(SB16_NAME)
        audiohw = sb16+adlib
        AUDIO_DRIVER = SADL.DRV
        condition = file_exists("$$(rootpath)\\SADL.DRV")
    end
    option[sb16]:
        name = $(SB16_NAME)
        audiohw = sb16; priority = 1
        AUDIO_DRIVER = SBPRO.DRV
        condition = file_exists("$$(rootpath)\\SBPRO.DRV")
    end
    option[mt32]:
        name = $(MT32_NAME)
        audiohw = sb16+mt32; priority = 2
        AUDIO_DRIVER = MT32.DRV
        condition = file_exists("$$(rootpath)\\MT32.DRV")
    end
    option[gmidi]:
        name = $(GMIDI_NAME)
        audiohw = sb16+gmidi; priority = 3
        AUDIO_DRIVER = GENMIDI.DRV
        condition = file_exists("$$(rootpath)\\GENMIDI.DRV")
    end
end

dynamicfile[]:
    path = $(rootpath)/RESOURCE.CFG
    contents = [[[$(CRLF)
        videoDrv  = VESA.DRV
        soundDrv  = $(AUDIO_DRIVER)
        audioDrv  = DACBLAST.DRV
        joyDrv    = NO
        mouseDrv  = NONE
        memoryDrv = NONE
        videoSpeed=200
        language  = 1
        audioSize = 64k
        smartdrv  = YES
        vmdSkip   = NO
        directory = .\
        movieDir  = .\VMD
        patchDir  = .\;.\PATCHES
        robot     = .\;.\PATCHES;.\ROBOT
        $(RESCONFIG)
    ]]]
end

//
// Sets movies to full size and detail
//
dynamicfile[]:
    path = $(rootpath)\PREF.DAT
    contents = [[[
        [[BINARY:0x01 0x00 0x00 0x00 0x00 0x00 0x7F 0x00 0x0F 0x00]]
    ]]]
end

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath);

//
// v1.1, CD
//
game[v1.1-cd]:
    name = v1.1, CD
    anchorfile = SIERRA.EXE
    file[]: crc = 82607fdb; size =     87524; name = INSTALL.EXE
