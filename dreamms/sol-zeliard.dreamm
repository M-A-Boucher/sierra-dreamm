// v2.0, Int. 3.13.91 (2x720K and 3x360K are identical)
//
game[v2.0-int-3.13.91]:
    name = v2.0, Int. 3.13.91
    imports = v1.208-int-12.20.90
    file[]: crc = 90f2005b; size =      3050; name = ZELIARD.EXE
    file[]: crc = 25d1a66c; size =    345295; name = ZELRES2.SAR
    file[]: crc = b6329ef9; size =    342434; name = ZELRES3.SAR
