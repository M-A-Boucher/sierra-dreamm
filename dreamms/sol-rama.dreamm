//
// Rama
//
desc[sol-rama]:
name = Rama
icon = sol-rama.png
machine = pc
rootpath = C:\SIERRA\RAMADOS
launch = $(rootpath)\sier.exe $(rootpath)\resource.cfg   
osenv = dos
fixdivover = true
mips = 60
audiohw = sb16
ramkb = 16384
videohw = svga
REGION = ""
CHARSET = ""

//
// file system
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)/DISC1; disc = 1
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)/DISC2; disc = 2
mount[]: vpath = D:\; srcpath = $(ifsinstallpath)/DISC3; disc = 3

dynamicfile[]:
    path = $(rootpath)/RESOURCE.CFG
    contents = [[[$(CRLF)
        videoDrv  = VESA.DRV
        soundDrv  = MIDNONE.DRV
        audioDrv  = DACBLAST.DRV
        joyDrv    = NO
        directory = \sierra\ramados
        cmd       = RAMADOS
        mouseDrv  = NONE
        memoryDrv = NONE
        minMemory = 1600k
        brightness= 0
        minCPU    = 486
        cd        = YES
        smartdrv  = YES
        maxSubmits= 48
        dacSize	  = 4k
                                    
        cdSpeed   = 4                 
        audio     = CD:\audio;CD:\PATCHES 
        resAud    = CD:\        		
        resSfx    = C:\sierra\ramados;CD:\        
        resMap    = CD:\              
        rescdisc  = CD:\              
        movieDir  = CD:\VMD           
        robot     = CD:\ROBOT         
        patchDir  = C:\sierra\ramados;CD:\PATCHES 
        CD:       = D:;        
    ]]]
end

charset[us]:
    height = 12
    char[1]: bits = 180`300`600`fff`fff
    char[3]: bits = 20c`60e`c07`cc3`cc3`ce7`ffe`73c
end

charset[it]:
    height = 16
    char[1]: bits = 0c00`1800`1800`3000`ffff`ffff
    char[3]: bits = 3000`7006`e007`c003`c003`c183`c183`6183`3ffe`1c7c
end

script[discswap]:
    code = [[[$(CRLF)
        func update()
        {
          if (!script_running(swapscript))
          {    
            disc = scraper_string("$$(REGION)", "$$(CHARSET)", 0xCA);
            if (disc != "") swapscript = script_run_async("swapauto", disc);
          }
        }

        func swapauto(disc)
        {
          input_lockout(true);
          echo("Inserting disc " + disc);
          disc_insert(disc); keyboard_type('\r');
          input_lockout(false);
        }
    ]]]
end

