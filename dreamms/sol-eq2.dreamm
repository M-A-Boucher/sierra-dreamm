//
// v1.0, Int. 2.5.93, 4x1.44M
//
game[v1.0-int-2.5.93-4x1.44m]:
    name = v1.0, Int. 2.5.93, 4x1.44M
    imports = v1.0-base
    anchorfile = RESOURCE.000
    file[]: crc = 479ada18; size =   4208192; name = RESOURCE.000
end

