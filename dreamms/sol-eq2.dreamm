    name = v1.0, Int. 2.5.93, 4x1.44M, Installer
    installid = v1.0-int-2.5.93-4x1.44m
    launch = DREAMM.BAT
    imports = v1.0-base
    anchorfile = SIERRA.EXE
    anchordepth = 1
