//
// v2.0, Int. 3.26.93, 4x1.44M
//
game[v2.0-int-3.26.93-4x1.44m]:
    name = v2.0, Int. 3.26.93, 4x1.44M
    imports = v2.0-base
    anchorfile = RESOURCE.000
    file[]: crc = b31bc686; size =   2000132; name = RESOURCE.000
    file[]: crc = 7797ff61; size =   3542466; name = RESOURCE.AUD
end

//
// v2.0, Int. 3.26.93, 4x1.44M, Installer
//
installer[v2.0-int-3.26.93-4x1.44m-installer]:
    name = v2.0, Int. 3.26.93, 4x1.44M, Installer
    installid = v2.0-int-3.26.93-4x1.44m
    mips = $(MIPS_MAX)
    launch = DREAMM.BAT
    imports = v2.0-base
    anchorfile = SIERRA.EXE
    anchordepth = 1
    file[]: crc = e8141961; size =     19918; name = PKDECOMP.EXE
    file[]: crc = 40754d1e; size =    440320; name = RESOURCE.P01
    file[]: crc = 9cefe719; size =   1454080; name = RESOURCE.P02
    file[]: crc = 176f40e3; size =    105732; name = RESOURCE.P03
    file[]: crc = dee54de6; size =   1276928; name = RESOURCE.A01
    file[]: crc = 2e0dcd7a; size =   1454439; name = RESOURCE.A02
end

