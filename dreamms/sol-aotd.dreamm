//
// Aces of the Deep
//
desc[sol-aotd]:

name = Aces of the Deep
icon = sol-aotd.png
machine = pc
osenv = dos
rootpath = C:\
launch = $(rootpath)\AOD.EXE
mips = $(MIPS_P75)
ramkb = 8192
filter = dynamix, sierra, simulation
videohw = vga

//
// sound configuration
//
config[sound]:
    title = Sound Configuration
    option[speaker]:
        name = $(SPEAKER_NAME)
        audiohw = speaker
        condition = file_exists("$$(rootpath)\\STD.DRV")
    end
    option[adlib]:
        name = $(ADLIB_NAME); 
        audiohw = adlib; priority = 1
        condition = file_exists("$$(rootpath)\\ADL.DRV")
    end
    option[mt32]:
        name = $(MT32_NAME)
        audiohw = mt32
        condition = file_exists("$$(rootpath)\\MT32.DRV")
    end
end

dynamicfile[]:
    path = $(rootpath)/RESOURCE.CFG
    contents = [[[$(CRLF)
 videoDrv  = VESA.DRV
 soundDrv  = ADL.DRV
 audioDrv  = DACBLAST.DRV
 joyDrv    = NO
space = 10000
cmd = aod
minCPU = 386
mouseDrv=none
memoryDrv=none
[SoundFX]
Driver#=E000
DMA=1
IRQ=7
PortAddress=220
[Music]
Driver#=A002
PortAddress=388
[SoundSet]
pathSoundPlay=.\sound\
pathDrivers=.\sound\
digiFile=.\sound\sonarret.raw
digiName=sonar ping
midiFile=.\sound\departrl.hmp
midiName=music
    ]]]
end

dynamicfile[]:
    path = $(rootpath)/DREAMM.BAT
    contents = [[[$(CRLF)
        MD INTRO
        MD SHELL
        MD SHELL\PROTYPER
        MD SHELL\SW
        MD SIM
        MD SIM\SAVE
        MD SOUND
        UNCHUNK.EXE RESOURCE.000 .\
        UNCHUNK.EXE RESOURCE.001 .\
        UNCHUNK.EXE RESOURCE.002 .\
        UNCHUNK.EXE RESOURCE.003 .\
        UNCHUNK.EXE RESOURCE.004 .\
    ]]]
end

//
// filesystem
//
mount[]: vpath = C:\        ; srcpath = $(ifsdeltapath)             ; writable = true;
mount[]: vpath = C:\        ; srcpath = $(ifsdeltapath)\SHELL\SCORES; writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath)

//
// v1.0, Int. 9.25.94
//
