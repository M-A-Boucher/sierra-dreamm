//
// Police Quest: SWAT 2
//
desc[sol-pqswat2]:

name = Police Quest: SWAT 2
icon = sol-pqswat2.png
machine = pc
osenv = windows 95
rootpath = C:\
launch = $(rootpath)\SETUP.EXE
mips = $(MIPS_MAX)
audiohw = gmidi
winres = 640x480x16
filter = sierra, strategy

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath); writable = true
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath);

//
// v1.0, CD
//
