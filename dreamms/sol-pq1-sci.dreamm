//
// v2.0, Int. 8.27.92, 5x1.44M
//
game[v2.0-int-8.27.92-5x1.44m]:
    name = v2.0, Int. 8.27.92, 5x1.44M
    imports = v2.0-base
    anchorfile = RESOURCE.00
    file[]: crc = b960c611; size =   6401433; name = RESOURCE.000
end

//
// v2.0, Int. 8.27.92, 5x1.44M, Installer
