    file[]: crc = a28a9e4d; size =      3273; name = EGA320.DRV
    file[]: crc = db0e22be; size =      2763; name = MCGA320.DRV
    file[]: crc = 3264b567; size =    511528; name = RESOURCE.001
    file[]: crc = f7c748e7; size =      1602; name = RESOURCE.MAP
    file[]: crc = 3891dc81; size =     59447; name = SCIV.EXE
    file[]: crc = 9f332d23; size =     60373; remove = SCIV256.EXE
    file[]: crc = b5eec20c; size =      2796; name = TANDY320.DRV
    file[]: crc = 6c230416; size =      3854; name = TANDY3V.DRV
    file[]: crc = f13c8668; size =       476; name = TANDYKBD.DRV
