//
// v1.000.060, Int. 10.19.90, 2x360K, 16 Color
//
game[v1.000.060-int-10.19.90-2x360k]:
    name = v1.000.060, Int. 10.19.90, 2x360K, 16 Color
    launch = SCIV.EXE
    imports = v1.000.060-int-10.19.90-1x720k
    anchorfile = RESOURCE.001
    file[]: crc = c0cf7df6; size =    202105; name = RESOURCE.001
    file[]: crc = 2ddcfe52; size =    341771; name = RESOURCE.002
    file[]: crc = 759a5d84; size =      1800; name = RESOURCE.MAP
end

end