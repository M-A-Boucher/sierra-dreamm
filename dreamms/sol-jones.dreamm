//
// Jones in the Fast Lane
//
desc[sol-jones]:

name = Jones in the Fast Lane
icon = sol-jones.png
machine = pc
osenv = dos
rootpath = C:\
launch = $(rootpath)\SCIV256.EXE
mips = $(MIPS_486DX_33)
nothrottle = 4
ramkb = 4096
filter = sierra, adventure
TANDY = 0

//
// graphics configuration
//
config[graphics]:
    title = Graphics Configuration
    option[tandy]: 
        name = $(TVIDEO_NAME)
        videohw = cga; machine = tandy
        VIDEO_DRIVER = TANDY320.DRV; SOUND_DRIVER = TANDY3V.DRV; TANDY = 1
        condition = file_exists("$$(rootpath)\\TANDY320.DRV") && file_exists("$$(rootpath)\\TANDY3V.DRV")
    end
    option[ega]:
        name = $(EGA_NAME)
        videohw = ega; priority = 1
        VIDEO_DRIVER = EGA320.DRV
        condition = file_exists("$$(rootpath)\\EGA320.DRV")
    end
    option[vga]:
        name = $(VGA_NAME);
        videohw = vga; priority = 2
        VIDEO_DRIVER = VGA320.DRV
        condition = file_exists("$$(rootpath)\\VGA320.DRV")
    end
end

//
// sound configuration
//
config[sound]:
    title = Sound Configuration
    condition = !$(TANDY)
    option[speaker]:
        name = $(SPEAKER_NAME)
        audiohw = speaker
        SOUND_DRIVER = STD.DRV
        condition = file_exists("$$(rootpath)\\STD.DRV")
    end
    option[cms]:
        name = $(CMS_NAME)
        audiohw = cms
        SOUND_DRIVER = CMS.DRV
        condition = file_exists("$$(rootpath)\\CMS.DRV")
    end
    option[adlib]:
        name = $(ADLIB_NAME)
        audiohw = adlib
        SOUND_DRIVER = ADL.DRV
        condition = file_exists("$$(rootpath)\\ADL.DRV")
    end
    option[sb16]:
        name = $(SB16_NAME)
        audiohw = sb16; priority = 1
        SOUND_DRIVER = SNDBLAST.DRV
        condition = file_exists("$$(rootpath)\\SNDBLAST.DRV")
    end
    option[mt32]:
        name = $(MT32_NAME)
        audiohw = mt32
        SOUND_DRIVER = MT32.DRV
        condition = file_exists("$$(rootpath)\\MT32.DRV")
    end
end

dynamicfile[]:
    path = $(rootpath)/RESOURCE.CFG
    contents = [[[$(CRLF)
        videoDrv  = $(VIDEO_DRIVER)
        soundDrv  = $(SOUND_DRIVER)
        joyDrv    = JOYSTICK.DRV
        kbdDrv    = IBMKBD.DRV
        mouseDrv  = STDMOUSE.DRV
        memoryDrv = ARM.DRV
        minHunk   = 260k
        patchDir  = .
   ]]]
end

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath); writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath);

//
// v1.000.060, Int. 10.19.90, 1x1.2M
//
game[v1.000.060-int-10.19.90-1x1.2m]:
    name = v1.000.060, Int. 10.19.90, 1x1.2M
    launch = SCIV256.EXE
    anchorfile = RESOURCE.001
    file[]: crc = 594590e7; size =      8033; name = ADL.DRV
    file[]: crc = d1588060; size =      3709; name = CMS.DRV
    file[]: crc = 1f125b48; size =       449; name = IBMKBD.DRV
    file[]: crc = baeddd01; size =       607; name = JOYSTICK.DRV
    file[]: crc = 15b7e056; size =      1989; name = MT32.DRV
    file[]: crc = 2545b160; size =    994487; name = RESOURCE.001
    file[]: crc = df72a9e3; size =      1602; name = RESOURCE.MAP
    file[]: crc = 9f332d23; size =     60373; name = SCIV256.EXE
    file[]: crc = 13e01cb8; size =      9489; name = SNDBLAST.DRV
    file[]: crc = c1c37f45; size =      1352; name = STD.DRV
    file[]: crc = 6c230416; size =      3854; name = TANDY3V.DRV
    file[]: crc = f13c8668; size =       476; name = TANDYKBD.DRV
    file[]: crc = d7283060; size =        13; name = VERSION
    file[]: crc = 5bb181a9; size =      3797; name = VGA320.DRV
end

//
// v1.000.060, Int. 10.19.90, 2x720K
//
game[v1.000.060-int-10.19.90-2x720k]:
    name = v1.000.060, Int. 10.19.90, 2x720K
    launch = SCIV256.EXE
    imports = v1.000.060-int-10.19.90-1x1.2m
    anchorfile = RESOURCE.001
    file[]: crc = a0a2d94e; size =    313476; name = RESOURCE.001
    file[]: crc = 29ec0c84; size =    719747; name = RESOURCE.002
    file[]: crc = 61debfd3; size =      1800; name = RESOURCE.MAP
end

