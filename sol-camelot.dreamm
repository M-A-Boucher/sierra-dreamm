    name = v1.000.046, Int. 0.000.685, 4x720K
    anchorfile = RESOURCE.001
    file[]: crc = c62381a5; size =      1049; name = __INSTH.BAT ; optional = true
    file[]: crc = 9f2cea3f; size =      9778; name = ADL.DRV
    file[]: crc = bb23b5b7; size =        37; name = CAMELOT.BAT ; optional = true
