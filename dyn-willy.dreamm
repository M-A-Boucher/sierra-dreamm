//
// The Adventures of Willy Beamish
//
desc[dyn-willy]:

name = The Adventures of Willy Beamish
icon = dyn-willy.png
machine = pc
osenv = dos
rootpath = C:\
launch = $(rootpath)\WILLY.EXE
mips = $(MIPS_486DX_33)
nothrottle = 3.5
ramkb = 4096
filter = dynamix, sierra, adventure
videohw = vga
VIDEODRV = 0x08
IS_CD = 0

//
// sound configuration
//
config[sound]:
    title = Sound Configuration
    option[speaker]:
        name = $(SPEAKER_NAME)
        audiohw = speaker
        AUDIODRV = 0x00
    end
    option[sb16]:
        name = $(SB16_NAME)
        audiohw = sb16
        AUDIODRV = 0x04
    end
    option[mt32]:
        name = $(MT32_NAME)
        audiohw = mt32; nothrottle = 6; priority = 1
        AUDIODRV = 0x03
    end
end

dynamicfile[]:
    condition = !$(IS_CD)
    path = $(rootpath)/RESOURCE.CFG
    contents = [[[
        [[BINARY:$(VIDEODRV) $(AUDIODRV)]] 
    ]]]
end

dynamicfile[]:
    condition = $(IS_CD)
    path = $(rootpath)/RESOURCE.CFG
    contents = [[[$(CRLF)
        soundDrv  = DTD.DRV
        joyDrv    = NO
        mouseDrv  = STDMOUSE.DRV
        memoryDrv = ARM.DRV
    ]]]
end

//
// filesystem
//
mount[]: vpath = C:\;         srcpath = $(ifsdeltapath); writable = true;
mount[]: vpath = $(rootpath); srcpath = $(ifsinstallpath);

//
// v1.0, Int. 9.25.91, 6x1.44M
//
game[v1.0-int-9.25.91-6x1.44m]:
    name = v1.01, Int. 9.25.91, 6x1.44M
    anchorfile = WILLY.EXE
    file[]: crc = 8d8a7fb7; size =     30887; name = INSTALL.COM ; optional = true
    file[]: crc = 8f2b2594; size =   1263007; name = VOLUME.001
    file[]: crc = 84b4788c; size =   1435102; name = VOLUME.002
