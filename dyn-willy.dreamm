    file[]: crc = 5794e75c; size =   1175486; name = VOLUME.006
    file[]: crc = 55ca81cc; size =      9896; name = VOLUME.RMF
    file[]: crc = 0a35d102; size =    225088; name = WILLY.EXE
end

